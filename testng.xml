<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="Mobile Automation Suite" parallel="tests" thread-count="2">

    <listeners>
        <listener class-name="listeners.ExecutionLifecycleListener"/>
        <listener class-name="listeners.SuiteListener"/>
        <listener class-name="listeners.TestListener"/>
        <listener class-name="listeners.AllureRunListener"/>
    </listeners>

    <test name="Android Tests" preserve-order="true">
        <parameter name="platformName" value="Android"/>
        <parameter name="platformVersion" value="13"/>
        <groups>
            <run>
                <exclude name="ios-only"/>
            </run>
        </groups>
        <classes>
            <class name="tests.LoginTests"/>
            <class name="tests.ProductTests"/>
            <class name="tests.CartTests"/>
            <class name="tests.CheckoutTests"/>
        </classes>
    </test>

    <test name="iOS Tests" preserve-order="true">
        <parameter name="platformName" value="iOS"/>
        <parameter name="platformVersion" value="26.5.1"/>
        <classes>
            <class name="tests.LoginTests"/>
            <class name="tests.ProductTests"/>
            <class name="tests.CartTests"/>
            <class name="tests.CheckoutTests"/>
        </classes>
    </test>

</suite>
